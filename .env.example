# ⚠️ ATENÇÃO: Variáveis com prefixo VITE_ ficam VISÍVEIS no navegador!
# Nunca coloque secrets sensíveis com prefixo VITE_.

# Supabase (anon key é público por design — ok no frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service Role Key — NUNCA exponha no frontend!
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini — SOMENTE no servidor (sem VITE_ = invisível no browser)
GEMINI_API_KEY=

# Backend API URL (o frontend aponta para o backend local ou remoto)
VITE_API_URL=http://localhost:3001

# Porta do servidor backend
PORT=3001

# CORS origin (URL do frontend em dev)
CORS_ORIGIN=http://localhost:5173

# UAZAPI (WhatsApp) — Mover para backend em versão futura
VITE_UAZAPI_BASE_URL=
VITE_UAZAPI_INSTANCE_TOKEN=
VITE_SUPERADMIN_WHATSAPP=
